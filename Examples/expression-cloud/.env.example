# bitHuman Expression Cloud
# Get credentials from https://www.bithuman.ai

# Required
BITHUMAN_API_SECRET=your_api_secret_here
OPENAI_API_KEY=sk-your_openai_key_here

# Avatar face -- provide ONE of these:
# Option 1: Face image (any photo with a face -- local path or URL)
BITHUMAN_AVATAR_IMAGE=https://example.com/face.jpg
# Option 2: Pre-built agent ID from www.bithuman.ai
# BITHUMAN_AGENT_ID=A78WKV4515

# Optional
OPENAI_VOICE=coral
