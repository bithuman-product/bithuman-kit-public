# bitHuman Expression Self-Hosted
# Copy this file: cp .env.example .env

# ── Required ─────────────────────────────────────────────────
BITHUMAN_API_SECRET=your_api_secret_here    # Get from: www.bithuman.ai > Developer
OPENAI_API_KEY=sk-your_openai_key_here      # For AI conversation (agent.py)

# ── Avatar Face (pick ONE) ───────────────────────────────────
# URL to any face photo:
BITHUMAN_AVATAR_IMAGE=https://thispersondoesnotexist.com
# Or local file (place in ./avatars/ first):
# BITHUMAN_AVATAR_IMAGE=/app/avatars/face.jpg
# Or pre-configured agent ID from bithuman.ai:
# BITHUMAN_AGENT_ID=

# ── Optional ─────────────────────────────────────────────────
OPENAI_VOICE=coral                          # OpenAI TTS voice
CUDA_VISIBLE_DEVICES=0                      # GPU index (for multi-GPU machines)
CUSTOM_GPU_TOKEN=
