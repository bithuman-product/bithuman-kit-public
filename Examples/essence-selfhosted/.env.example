# bitHuman Essence Self-Hosted
# Copy this file: cp .env.example .env

# ── Required ─────────────────────────────────────────────────
BITHUMAN_API_SECRET=your_api_secret_here    # Get from: www.bithuman.ai > Developer
OPENAI_API_KEY=sk-your_openai_key_here      # For AI conversation (agent.py, conversation.py)

# ── Model Path (for terminal scripts) ───────────────────────
BITHUMAN_MODEL_PATH=./models/avatar.imx     # Download from bithuman.ai or generate via ../api/generation.py

# ── Optional ─────────────────────────────────────────────────
OPENAI_VOICE=coral                          # OpenAI TTS voice
