# bitHuman Essence Self-Hosted
# Get credentials from https://www.bithuman.ai

# Required
BITHUMAN_API_SECRET=your_api_secret_here
OPENAI_API_KEY=sk-your_openai_key_here

# For terminal scripts (quickstart.py, microphone.py, conversation.py)
BITHUMAN_MODEL_PATH=./models/avatar.imx

# Optional
OPENAI_VOICE=coral
