# bitHuman Expression Self-Hosted
# Requires NVIDIA GPU with 8GB+ VRAM

# Required
BITHUMAN_API_SECRET=your_api_secret_here
OPENAI_API_KEY=sk-your_openai_key_here

# Avatar face -- provide ONE of these:
# Option 1: Face image (local path inside container, or URL)
BITHUMAN_AVATAR_IMAGE=https://example.com/face.jpg
# Option 2: Use local file (place in ./avatars/, reference as /app/avatars/face.jpg)
# BITHUMAN_AVATAR_IMAGE=/app/avatars/face.jpg
# Option 3: Pre-configured avatar ID
# BITHUMAN_AGENT_ID=A05XGC2284

# Optional
OPENAI_VOICE=coral
# CUSTOM_GPU_URL=http://expression-avatar:8089/launch  # Override if running expression-avatar elsewhere
CUDA_VISIBLE_DEVICES=0
CUSTOM_GPU_TOKEN=
